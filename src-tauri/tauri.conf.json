{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Grommet Marks",
  "version": "0.2.5",
  "identifier": "cz.grommet.marksapp",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Grommet Marks App",
        "width": 860,
        "height": 900,
        "minWidth": 700,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "appPosition": { "x": 180, "y": 220 },
        "applicationFolderPosition": { "x": 480, "y": 220 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5QjVCNkRGRUZDREJERjQKUldUMHZjM3YzN2ExNll4VU5laTJsQUh5alZ5ZnF1NXZLNXRGWDRSaVJ3RlRhV2x1ek1BcDJnOTAK",
      "endpoints": [
        "https://github.com/h0nyik/GrommeR/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
